    "@mui/x-data-grid": "^6.0.2",
    "@types/topojson-client": "^3.1.5",
    "axios": "^1.3.4",
    "d3": "^7.8.5",
    "date-fns": "^2.29.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^8.0.7",
    "react-router-dom": "^6.8.1",
    "recharts": "^2.5.0",
