    "@vitejs/plugin-react-swc": "^4.2.3",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.0.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-import": "^2.25.0",
    "eslint-plugin-react": "^7.25.0",
