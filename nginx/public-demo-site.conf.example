# Example: public HTTPS site — static SPA (Vite dist) + FastAPI /api
# Copy fragments into your real nginx config; adjust ssl_certificate paths and upstream.
# Build SPA: cd web && npm ci && npm run build  → artifacts in web/dist

upstream news_intel_api {
    # API bound to loopback only (recommended)
    server 127.0.0.1:8000;
}

server {
    listen 80;
    listen [::]:80;
    server_name demo.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name demo.example.com;

    # ssl_certificate /etc/letsencrypt/live/demo.example.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/demo.example.com/privkey.pem;

    root /var/www/news-intelligence/web/dist;
    index index.html;

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        proxy_pass http://news_intel_api/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }
}
