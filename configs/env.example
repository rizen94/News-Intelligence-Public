# News Intelligence System Environment Configuration
# Example Environment Template - Copy to .env and customize

# Database Configuration
#
# Primary: PostgreSQL on Widow (same target the API connection pools use). Example:
#   DB_HOST=192.168.93.101
#   DB_PORT=5432
#   DB_NAME=news_intel
# With PgBouncer on Widow: DB_PORT=6432 (see docs/PGBOUNCER_AND_CONNECTION_BUDGET.md)
#
# Backup-only (NAS): SSH tunnel to localhost:5433 — do not use for normal API operation.
#   DB_HOST=localhost
#   DB_PORT=5433
#   + run scripts/setup_nas_ssh_tunnel.sh when you intentionally attach to NAS Postgres.
DB_HOST=192.168.93.101
DB_PORT=5432
DB_NAME=news_intel
DB_USER=your_db_user_here
DB_PASSWORD=your_db_password_here

# Client pool budget (per API/worker process). Defaults match api/shared/database/connection.py.
# With PgBouncer, many client slots multiplex to fewer PostgreSQL backends.
DB_POOL_UI_MIN=2
DB_POOL_UI_MAX=16
DB_POOL_WORKER_MIN=2
DB_POOL_WORKER_MAX=20
# Small pool for automation health_check + automation_run_history for that phase only
DB_POOL_HEALTH_MIN=1
DB_POOL_HEALTH_MAX=2
DB_HEALTH_GETCONN_TIMEOUT_SECONDS=2
DB_HEALTH_STATEMENT_TIMEOUT_MS=5000
DB_POOL_SA_SIZE=3
DB_POOL_SA_OVERFLOW=8
# DB_UI_GETCONN_TIMEOUT_SECONDS=3
# DB_WORKER_GETCONN_TIMEOUT_SECONDS=30

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
# Optional LLM response cache (Ollama caller): same Redis; bust cache when prompts/models change
# NEWS_INTEL_LLM_CACHE_REDIS=false
# NEWS_INTEL_LLM_CACHE_VERSION=1
# REDIS_URL=redis://localhost:6379/0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
# scripts/restart_api_with_db.sh uses API_PORT (or NI_API_PORT) only to stop/start the listener — avoids pkill matching other uvicorn apps (e.g. Open WebUI).
# NI_API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# Frontend Configuration
FRONTEND_PORT=3000
FRONTEND_HOST=0.0.0.0

# Security Configuration
JWT_SECRET=your_jwt_secret_here_change_this
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
ENCRYPTION_KEY=your_encryption_key_here_change_this

# API exposure (see docs/SECURITY_OPERATIONS.md)
# development = permissive CORS/hosts, OpenAPI on, detailed 500 errors
# production = set CORS + trusted hosts explicitly; OpenAPI off by default
NEWS_INTEL_ENV=development
# NEWS_INTEL_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# NEWS_INTEL_TRUSTED_HOSTS=localhost,127.0.0.1,your-api-hostname
# NEWS_INTEL_ENABLE_API_DOCS=false
# NEWS_INTEL_RATE_LIMIT_PER_MINUTE=120
# NEWS_INTEL_SECURITY_MIDDLEWARE=false

# Public HTTPS demo (see docs/PUBLIC_DEPLOYMENT.md)
# When true, Host header must match NEWS_INTEL_DEMO_HOSTS (comma-separated, no port) OR set NEWS_INTEL_DEMO_READ_ONLY_ALL=true for a single-purpose demo server.
# NEWS_INTEL_DEMO_READ_ONLY=true
# NEWS_INTEL_DEMO_HOSTS=demo.example.com
# NEWS_INTEL_DEMO_READ_ONLY_ALL=false
# Optional: comma-separated path prefixes allowing POST in demo (default: none)
# NEWS_INTEL_DEMO_POST_ALLOWLIST=

# AutomationManager (main GPU host only): offload RSS + DB-adjacent phases to Widow cron
# See docs/WIDOW_DB_ADJACENT_CRON.md — Widow and main must share the same api/config/domains/*.yaml
# so collect_rss_feeds ingests every active silo. After new-domain migrations: run
#   PYTHONPATH=api uv run python api/scripts/ensure_domain_silo_alignment.py
# AUTOMATION_SKIP_RSS_IN_COLLECTION_CYCLE=true
# Leave unset for full unified pipeline. Optional comma-separated phase names to disable temporarily.
# AUTOMATION_DISABLED_SCHEDULES=

# Workload-driven cooldown tuning: when WORKLOAD_BALANCER_ENABLED=true, backfill phases re-enqueue
# sooner when pending ≫ batch (code default for the flag is false — turn on for faster drain).
# Default phase set includes claim_extraction, claims_to_facts, document_processing, storyline_discovery, …
# WORKLOAD_BALANCER_ENABLED=true
# WORKLOAD_BALANCER_PHASES=document_processing,timeline_generation,event_extraction,storyline_discovery
# Hybrid resource router (phase defaults + CPU/GPU/DB headroom adjustments)
# AUTOMATION_DYNAMIC_RESOURCE_ROUTING_ENABLED=true
# Gateway thresholds for gradual ramp tuning (headroom is 0..1 where 1 means free capacity).
# GPU below this is treated as saturated; above *_EXTRA headroom gets faster enqueue.
# AUTOMATION_ROUTER_GPU_SATURATED_HEADROOM=0.15
# AUTOMATION_ROUTER_GPU_EXTRA_HEADROOM=0.55
# CPU below this is treated as hot; above *_EXTRA headroom gets faster enqueue.
# AUTOMATION_ROUTER_CPU_HOT_HEADROOM=0.20
# AUTOMATION_ROUTER_CPU_EXTRA_HEADROOM=0.55
# DB worker pool below this headroom throttles DB-heavy phases; above *_EXTRA accelerates them.
# AUTOMATION_ROUTER_DB_PRESSURE_HEADROOM=0.20
# AUTOMATION_ROUTER_DB_EXTRA_HEADROOM=0.65
#
# --- Pipeline throughput runbook (GPU vs CPU vs DB) ---
# Fewer overlapping GPU-heavy phases: lower AUTOMATION_MAX_CONCURRENT_TASKS and/or MAX_CONCURRENT_OLLAMA_TASKS first;
# optionally lower AUTOMATION_PER_PHASE_CONCURRENT_CAP or set AUTOMATION_PER_PHASE_CONCURRENT_CAP_OVERRIDES e.g.
# topic_clustering:1,storyline_processing:1 (tune to your schedule). Resource router: AUTOMATION_DYNAMIC_RESOURCE_ROUTING_ENABLED
# and AUTOMATION_ROUTER_GPU_SATURATED_HEADROOM / *_EXTRA_HEADROOM. Raise OLLAMA_GPU_CONCURRENCY or MAX_CONCURRENT_OLLAMA_TASKS
# only if GPU VRAM and inference latency stay healthy (watch nvidia-smi + Ollama logs).
# Extraction on CPU host: OLLAMA_DUAL_HOST_ROUTING_ENABLED=true with OLLAMA_CPU_HOST vs OLLAMA_GPU_HOST — structured phases
# (claim_extraction, entity_extraction, event_extraction) use the CPU lane; narrative work uses the GPU lane (see automation_manager GPU_LANE_PHASES).
# Extraction throughput: CLAIM_EXTRACTION_BATCH_LIMIT, CLAIM_EXTRACTION_PARALLEL, ENTITY_EXTRACTION_PARALLEL, EVENT_EXTRACTION_PARALLEL
# — raise until the CPU host, DB pool, or model latency flattens. Keep claim_extraction:1 in AUTOMATION_PER_PHASE_CONCURRENT_CAP_OVERRIDES
# so one drain runs at a time; scale fanout with CLAIM_EXTRACTION_PARALLEL inside that task, not more queued claim_extraction tasks.
# DB-heavy phases (context_sync, claims_to_facts, dedupe): right-size DB_POOL_WORKER_* vs Postgres max_connections; tune CLAIMS_TO_FACTS_BATCH_LIMIT,
# EXTRACTED_CLAIMS_DEDUPE_BATCH_SIZE, NIGHTLY_* limits to avoid long transactions overlapping other work.
#
# --- Faster backlog burn-down & scheduling (merge into .env; validate vs Postgres max_connections / PgBouncer) ---
# All-in-one template (copy or append): configs/env.aggressive_burn_down.env
# Raises parallel work: watch Monitor (DB pool, Ollama errors, GPU VRAM). Step up gradually if stable.
# WORKLOAD_BALANCER_ENABLED=true
# AUTOMATION_SCHEDULER_TICK_SECONDS=3
# AUTOMATION_WORKLOAD_MIN_COOLDOWN_SECONDS=5
# AUTOMATION_MAX_CONCURRENT_TASKS=20
# AUTOMATION_EXECUTOR_MAX_WORKERS=10
# MAX_CONCURRENT_OLLAMA_TASKS=20
# DB_POOL_WORKER_MAX=36
# OLLAMA_CPU_CONCURRENCY=8
# OLLAMA_GPU_CONCURRENCY=8
# COLLECTION_THROTTLE_PENDING_THRESHOLD=2800
# Router: throttle GPU/DB-heavy phases only when tighter — more enqueue when headroom exists (defaults above are conservative).
# AUTOMATION_ROUTER_GPU_SATURATED_HEADROOM=0.08
# AUTOMATION_ROUTER_DB_PRESSURE_HEADROOM=0.12
# CLAIM_EXTRACTION_BATCH_LIMIT=3500
# CLAIM_EXTRACTION_PARALLEL=40
# CLAIMS_TO_FACTS_BATCH_LIMIT=15000
# NIGHTLY_CLAIM_EXTRACTION_BATCH_LIMIT=500
# NIGHTLY_CLAIMS_TO_FACTS_BATCH_LIMIT=1000
#   (omit NIGHTLY_CLAIMS_TO_FACTS_BATCH_LIMIT to match CLAIMS_TO_FACTS_BATCH_LIMIT)
# ENTITY_EXTRACTION_PARALLEL=8
# ENTITY_EXTRACTION_ARTICLES_PER_DOMAIN=40
# EVENT_EXTRACTION_PARALLEL=12
# NIGHTLY_CONTEXT_SYNC_LIMIT_PER_DOMAIN=350
# NIGHTLY_ENRICHMENT_BATCH_SIZE=120
# EXTRACTED_CLAIMS_DEDUPE_BATCH_SIZE=10000
# RSS_MAX_ENTRIES_PER_FEED=150

# collection_cycle is not scheduled when sum of pending phases exceeds threshold (workload-driven mode).
# Default excludes document_processing so PDF backlog does not block RSS. Empty COLLECTION_THROTTLE_EXCLUDE_PHASES = exclude nothing.
# COLLECTION_THROTTLE_PENDING_THRESHOLD=1200
# COLLECTION_THROTTLE_EXCLUDE_PHASES=document_processing
# COLLECTION_THROTTLE_EXTRA_PHASES=

# Fact verification: Wikipedia REST overlap check in verify_claim (disable for air-gapped)
# FACT_VERIFY_WIKIPEDIA=true
# Wikidata entity label/description overlap + year alignment (dated events)
# FACT_VERIFY_WIKIDATA=true
# GDELT DOC API mention density — low-weight signal only
# FACT_VERIFY_GDELT=true
# finance.articles with sec.gov URLs matching claim terms (finance domain only)
# FACT_VERIFY_SEC_FINANCE=true
# Llama 8B entailment when corroboration is borderline (needs Ollama; skip if nested event loop)
# FACT_VERIFY_ENTAILMENT_LLM=true

# Optional: shared secret for POST /api/system_monitoring/cron_heartbeat (cron job markers in automation_run_history)
# CRON_HEARTBEAT_KEY=

# Monitoring Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_password_here
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090

# NAS Storage Configuration
NAS_BASE_PATH=/mnt/nas/news-intelligence
NAS_DATA_PATH=/mnt/nas/news-intelligence/data
# Single rolling DB dump (homelab policy — one file, no dated retention). See docs/DATABASE_BACKUP.md
# Typical CIFS mount: //192.168.93.100/public/Data Lake Storage/... → /mnt/nas/Data Lake Storage/...
NAS_BACKUP_PATH=/mnt/nas/Data Lake Storage/news-intelligence/database-backup
NAS_LOGS_PATH=/mnt/nas/news-intelligence/logs

# Docker Configuration
DOCKER_NETWORK=news-intelligence-network
DOCKER_COMPOSE_PROFILE=full

# Feature Flags
ENABLE_MONITORING=true
ENABLE_SSL=true
ENABLE_DOMAIN_ROUTING=true
ENABLE_NAS_STORAGE=true

# Development/Production Mode
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# External Services
ML_SERVICE_URL=http://localhost:8001
RAG_SERVICE_URL=http://localhost:8002

# Finance domain — external data sources (see api/config/sources.yaml)
# Get key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# Historic context (Finance Analysis date range): news from date range. Get key at https://newsapi.org/register
NEWS_API_KEY=
# Politics — Congress.gov API v3 (bill text vs media claims). Free key: https://api.congress.gov/sign-up/
CONGRESS_GOV_API_KEY=
# Default Congress session when an article cites H.R./S. without "Nth Congress" (automation legislative_references)
# LEGISLATIVE_DEFAULT_CONGRESS=118
# How far back to scan articles for bill citations (days)
# LEGISLATIVE_SCAN_ARTICLE_DAYS=90
# For GDELT BigQuery (future)
BIGQUERY_PROJECT_ID=
# SEC EDGAR requires identifying User-Agent (format: AppName contact@example.com)
EDGAR_USER_AGENT=NewsIntelligence research@example.com
# Optional: custom archive path for large downloads
NEWS_INTEL_ARCHIVE_DIR=/media/pete/Fortress2/news-intelligence-archive

# Backup Configuration (see docs/DATABASE_BACKUP.md — single latest pg_dump on NAS; RPO ~24h)
# scripts/db_backup_single_latest.sh uses NAS_BACKUP_PATH by default via BACKUP_BASE in the script body
BACKUP_RETENTION_DAYS=0
BACKUP_SCHEDULE=0 3 * * *

# Performance Configuration
MAX_CONNECTIONS=100
CONNECTION_TIMEOUT=30
QUERY_TIMEOUT=60

# Email Configuration (if needed)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Webhook Configuration (if needed)
WEBHOOK_SECRET=
WEBHOOK_TIMEOUT=30

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,txt,doc,docx

# Search Configuration
SEARCH_RESULTS_LIMIT=50
SEARCH_TIMEOUT=10

# RSS Configuration
RSS_UPDATE_INTERVAL=300
RSS_MAX_ARTICLES=1000
# Max feed entries processed per feed per collect_rss_feeds run (default 100, max 500)
# RSS_MAX_ENTRIES_PER_FEED=100
RSS_TIMEOUT=30
# Shared HTTP client: User-Agent and optional HTML page → discover <link rel=alternate> RSS/Atom
# RSS_HTTP_USER_AGENT=NewsIntelligence/1.0 (+https://example.com)
# RSS_HTML_FEED_DISCOVERY=false
# Plain-text length below this (tags stripped) triggers trafilatura on the article URL at RSS ingest (default 900)
# RSS_FULLTEXT_FETCH_THRESHOLD_CHARS=900
# RSS_ALWAYS_FETCH_FULLTEXT=false
#
# Domain registry is driven by ``public.domains`` (merged with api/config/domains/*.yaml). Legacy URL keys
# politics / finance legacy keys are retired — run migration 210 (and 211 for template rename) and copy silo data first;
# see docs/LEGACY_DOMAIN_RETIREMENT.md.
#
# Template silos politics-2 / finance-2 (migration 201): after ``switch_domain_rss_ingest.py`` turns off
# legacy ``politics`` feeds, set **RSS_INGEST_EXCLUDE_DOMAIN_KEYS=politics** so no code path double-collects
# if a feed URL ever exists in two schemas. New articles then land only in ``politics_2`` (domain politics-2).
# POLITICS_PG_CONTENT_DOMAIN_KEY=politics   # default; maps to schema politics_2 (see docs/DOMAIN_CUTOVER_POLITICS_FINANCE.md)
# Finance cutover (when ready):
# RSS_INGEST_EXCLUDE_DOMAIN_KEYS=politics,finance
# FINANCE_PG_CONTENT_DOMAIN_KEY=finance
# FINANCE_CONTEXT_DOMAIN_KEY=finance
#
# Pipeline: template-only processing (automation, enrichment, ML, backlog iterators). Optional allowlist
# wins over unlisted active domains; exclusions apply after the allowlist.
# Storyline synthesis and Monitor “Synthesis last 1h/4d by domain” use this scope (not legacy url_schema_pairs).
# PIPELINE_INCLUDE_DOMAIN_KEYS=legal,medicine,artificial-intelligence,finance,politics
# PIPELINE_EXCLUDE_DOMAIN_KEYS=politics,finance
# Match RSS collection to the same silos as the pipeline (recommended with INCLUDE above):
# RSS_INGEST_MIRROR_PIPELINE=true
#
# Entity extraction: only link to existing ``entity_canonical`` (seeded / known); skip unmatched mentions.
# ENTITY_EXTRACTION_RESOLVE_STRICT_DOMAIN_KEYS=legal,medicine,artificial-intelligence,finance,politics
#
# Unified nightly backlog drain (01:00–07:00 local): set false to use main AutomationManager intervals only.
# NIGHTLY_UNIFIED_PIPELINE_ENABLED=false
#
# Legislative bill scan (Congress.gov) — use template politics when legacy is frozen:
# LEGISLATIVE_SCAN_DOMAIN_KEYS=politics,legal

# Ollama — model names and routing (see api/config/settings.py, shared/services/ollama_model_policy.py)
# OLLAMA_HOST=http://localhost:11434
# Optional dual-host routing (CPU + GPU). Keep disabled to use OLLAMA_HOST for all calls.
# OLLAMA_DUAL_HOST_ROUTING_ENABLED=false
# OLLAMA_CPU_HOST=http://localhost:11434
# OLLAMA_GPU_HOST=http://localhost:11434
# OLLAMA_CPU_CONCURRENCY=6
# OLLAMA_GPU_CONCURRENCY=6
# When dual routing is on: STRUCTURED_EXTRACTION (claim/entity/event extraction) + embeddings use CPU host/semaphore;
# topic clustering HTTP uses OLLAMA_CPU_HOST by default. Narrative/finisher kinds use GPU host. Verify:
# GET /api/system_monitoring/automation/status → data.resource_router.llm_endpoints (when not pipeline-busy).
# OLLAMA_MODEL_PRIMARY=llama3.1:8b
# OLLAMA_MODEL_SECONDARY=mistral-nemo:12b
# OLLAMA_MODEL_EMBEDDING=nomic-embed-text
# OLLAMA_MODEL_PHI=phi3.5:latest
# OLLAMA_MODEL_EXTRACTION=qwen2.5:7b
OLLAMA_USE_QWEN_FOR_EXTRACTION=true
OLLAMA_USE_PHI_FOR_FAST_SIMPLE=true
OLLAMA_USE_SECONDARY_FOR_EXTRACTION=true
# FINANCE_OLLAMA_GENERATION_HIGH=  (defaults to OLLAMA_MODEL_SECONDARY)
# Claim pipeline throughput (contexts → extracted_claims → versioned_facts). Tune to GPU / DB / Ollama.
# CLAIM_EXTRACTION_BATCH_LIMIT=2000
# CLAIM_EXTRACTION_PARALLEL=32
#   Set <=0 to fan out one asyncio task per context up to min(batch, CLAIM_PIPELINE_MAX_FETCH).
# Nightly unified drain chunk size for one claim_extraction invocation (prevents multi-hour single runs).
# NIGHTLY_CLAIM_EXTRACTION_BATCH_LIMIT=250
# Extracted-claims dedupe (AutomationManager phase extracted_claims_dedupe + scripts/merge_duplicate_extracted_claims.py)
# EXTRACTED_CLAIMS_DEDUPE_BATCH_SIZE=8000
# EXTRACTED_CLAIMS_DEDUPE_MAX_BATCHES=5

# CLAIMS_TO_FACTS_BATCH_LIMIT=10000
# Min confidence for promotion + backlog count (default 0.75)
# CLAIMS_TO_FACTS_MIN_CONFIDENCE=0.75
# Throughput: raise batch limit (and DB_POOL_WORKER_*) after confirming DB healthy; lower min
# confidence widens backlog + work. Parallel workers: e.g.
# AUTOMATION_PER_PHASE_CONCURRENT_CAP_OVERRIDES=claim_extraction:1,claims_to_facts:2
# (promotion uses FOR UPDATE OF extracted_claims SKIP LOCKED — disjoint batches; 0 in overrides = unlimited).
# Daytime scheduled: loop promote until idle (CLAIMS_TO_FACTS_DRAIN=true) — one automation task, many batches.
# CLAIMS_TO_FACTS_DRAIN=true
# CLAIMS_TO_FACTS_DRAIN_MAX_BATCHES=0
# CLAIMS_TO_FACTS_DRAIN_MAX_SECONDS=0
# CLAIMS_TO_FACTS_DRAIN_MAX_ZERO_PROMOTE_BATCHES=5
# Nightly sequential: one promote per run_nightly_sequential_phase; omit NIGHTLY_CLAIMS_TO_FACTS_BATCH_LIMIT to match
# CLAIMS_TO_FACTS_BATCH_LIMIT (same slice size day and night). Set explicitly to cap a smaller nightly chunk.
# NIGHTLY_CLAIMS_TO_FACTS_BATCH_LIMIT=500
# Optional strict merged-ID dedupe check (reads metadata.source_claim_ids in versioned_facts).
# Keep disabled for throughput unless you add supporting indexes / can absorb extra DB cost.
# CLAIMS_TO_FACTS_CHECK_MERGED_SOURCE_IDS=false
# Monitor/automation backlog count for claims_to_facts: promotable_hint (default, smaller, ~first-tier resolvable)
# or batch_candidate (larger pool = SQL batch rows before fuzzy resolution, still excludes generic subjects).
# CLAIMS_TO_FACTS_BACKLOG_COUNT_MODE=promotable_hint
# Event tracking backlog reduction: only consider recent contexts with enough body text.
# EVENT_TRACKING_MAX_AGE_DAYS=14
# EVENT_TRACKING_MIN_CONTENT_LEN=180
# Min title+body length for contexts counted in claim_extraction backlog (matches extract_claims_for_context gate).
# CLAIM_EXTRACTION_MIN_TEXT_LEN=80
# Monitor backlog: require metadata.pipeline.<phase>.last_pass_at for phases below (stops infinite re-queue when outputs are empty).
# Set false to restore legacy counts (article_entities, timeline_processed, extracted_claims rows only, etc.).
# PIPELINE_BACKLOG_USE_PASS_MARKERS=true
# Per-phase override (underscores): ENTITY_EXTRACTION_BACKLOG_USE_PASS_MARKER, METADATA_ENRICHMENT_BACKLOG_USE_PASS_MARKER,
# STORYLINE_DISCOVERY_BACKLOG_USE_PASS_MARKER, EVENT_EXTRACTION_BACKLOG_USE_PASS_MARKER, SENTIMENT_ANALYSIS_BACKLOG_USE_PASS_MARKER,
# CLAIM_EXTRACTION_BACKLOG_USE_PASS_MARKER, EVENT_TRACKING_BACKLOG_USE_PASS_MARKER
# Topic clustering graduation threshold (used when iterative refinement is on; see below).
# TOPIC_CLUSTERING_GRADUATION_CONFIDENCE=0.88
# Monitor/automation pending: count only articles without metadata.pipeline.topic_clustering.last_pass_at (default).
# Set false to restore legacy backlog = low avg assignment confidence (high churn).
# TOPIC_CLUSTERING_BACKLOG_USE_PASS_MARKER=true
# When false (default): automation does not loop on low-confidence rows; one successful pass sets last_pass_at.
# When true: legacy churn — re-select articles below graduation confidence each cycle (expensive).
# TOPIC_CLUSTERING_ITERATIVE_REFINEMENT=false
# Nightly unified drain fairness/chunking: per-phase max loops per sweep (phase:loops, comma-separated).
# Keep claim_extraction/claims_to_facts high for backlog burn-down, but not infinite to avoid starvation.
# Backlog-weighted default shown below (override per host as needed):
# NIGHTLY_SEQUENTIAL_PHASE_LOOP_CAPS=claim_extraction:18,claims_to_facts:24,extracted_claims_dedupe:8,claim_subject_gap_refresh:6,entity_extraction:8,event_tracking:10,topic_clustering:10,entity_profile_sync:6,entity_profile_build:6,event_extraction:6,proactive_detection:4,storyline_discovery:4
# When BATCH_LIMIT is <=0, slice size falls back to CLAIM_PIPELINE_MAX_FETCH (default 500000 claim contexts / slice).
# CLAIM_PIPELINE_MAX_FETCH=500000
#
# Claims → entity_profiles resolution (api/services/claim_extraction_service.py)
# CLAIM_RESOLVE_SUBSTRING_MAX_CANON_LEN=120
# CLAIM_RESOLVE_TRGM_THRESHOLD_SHORT=0.52
# CLAIM_RESOLVE_TRGM_THRESHOLD_LONG=0.40
# Optional strict mode: for listed domains, only keep extracted claims whose subject already matches
# entity_profiles metadata canonical_name or {schema}.entity_canonical canonical_name exactly (normalized).
# Useful to avoid cycles on vague/novel subjects in high-backlog silos.
# CLAIM_EXTRACTION_REQUIRE_SEEDED_DOMAIN_KEYS=legal,medicine,artificial-intelligence
#
# entity_profile_sync: context_entity_mentions backfill after bulk profile upsert
# ENTITY_PROFILE_SYNC_MENTION_BACKFILL_LIMIT=10000
# ENTITY_PROFILE_SYNC_MENTION_BACKFILL_ROUNDS=3
# Entity extraction phase: concurrent LLM calls per batch (default 4, max 16); articles per domain per run (default 20, max 120)
# ENTITY_EXTRACTION_PARALLEL=4
# ENTITY_EXTRACTION_ARTICLES_PER_DOMAIN=20
# Terminal skip-state caps (after N per-article failures, set metadata.pipeline_skip.*_skip=true).
# These rows are excluded from phase selection + backlog counts to stop wasted requeue loops.
# ENTITY_EXTRACTION_MAX_FAILURES=3
# SENTIMENT_ANALYSIS_MAX_FAILURES=3
# QUALITY_SCORING_MAX_FAILURES=3
# EVENT_EXTRACTION_MAX_FAILURES=2
# Max people/orgs/subjects/recurring_events per article from each LLM array (default 50)
# ENTITY_EXTRACTION_MAX_PER_TYPE=50
# After a non-empty entity_extraction batch: sync profiles + backfill context_entity_mentions (main host only)
# ENTITY_EXTRACTION_POST_SYNC=true
# ENTITY_EXTRACTION_POST_MENTION_LIMIT=1500
#
# Surname family clusters (Trump → "Trump family" + member_of_family edges); see entity_resolution_service
# SURNAME_FAMILY_MIN_MEMBERS=2
# SURNAME_FAMILY_MAX_MEMBERS=24
# SURNAME_FAMILY_MIN_SURNAME_LEN=4
# Monitor backlog_status: threshold alerts (resource_dashboard)
# NEWS_INTEL_ALERT_ARTICLE_BACKLOG=2000
# NEWS_INTEL_ALERT_CONTEXT_BACKLOG=500
# Documentation-only: mark that DB_PORT points at PgBouncer
# NEWS_INTEL_PGBOUNCER_TARGET=pgbouncer

# Deduplication Configuration
DEDUP_SIMILARITY_THRESHOLD=0.8
DEDUP_BATCH_SIZE=100

# Event deduplication (chronological_events v5 — api/services/event_deduplication_service.py)
# Merges point duplicates at canonical_event_id; canonical row keeps source_count / last_corroborated_at (multi-source tracking).
# Lower similarity / overlap / margin → more aggressive merges; raise skip-margin threshold to accept high-cosine pairs without margin test.
# EVENT_DEDUP_SIMILARITY_THRESHOLD=0.85
# EVENT_DEDUP_ENTITY_OVERLAP_MIN=2
# EVENT_DEDUP_EMBEDDING_TOP_K=10
# EVENT_DEDUP_EMBEDDING_MARGIN=0.1
# EVENT_DEDUP_EMBEDDING_SKIP_MARGIN_IF_SIM_GE=0.95
# EVENT_DEDUP_BORDERLINE_SIM=0.9
# EVENT_DEDUP_BORDERLINE_MAX_SECONDS_APART=86400
# EVENT_DEDUP_DISABLE_TEMPORAL_BORDERLINE=false
# Backlog metrics: phases without BATCH_SIZE_PER_TASK used to subtract 0 → pending and “>1 batch” matched; default subtract is 1 row per unknown phase.
# BACKLOG_METRICS_DEFAULT_BATCH_SIZE=1

# Intelligence Configuration
INTELLIGENCE_UPDATE_INTERVAL=600
INTELLIGENCE_BATCH_SIZE=50

# Automation Configuration
AUTOMATION_ENABLED=true
AUTOMATION_SCHEDULE=0 */6 * * *
# Articles with created_at >= this instant use stricter enrichment gates (ML/context SQL + RSS pending for long feed-only body). Omit to keep legacy behavior for all rows.
# STRICT_ARTICLE_ENRICHMENT_GATES_SINCE=2026-03-24T00:00:00+00:00
# Before workers start: SELECT 1 on worker + health pools (retries if DB is slow to come up)
# AUTOMATION_SKIP_STARTUP_PREFLIGHT=true
# AUTOMATION_STARTUP_HEALTH_CHECK_ATTEMPTS=3
# AUTOMATION_STARTUP_HEALTH_CHECK_DELAY_SEC=2
# Concurrency controls (raise gradually while watching Monitor CPU/GPU + DB pool saturation)
# Dual-host: OLLAMA_CPU_CONCURRENCY / OLLAMA_GPU_CONCURRENCY cap per-lane Ollama HTTP concurrency (increase CPU only to raise CPU-host load without raising GPU cap).
# MAX_CONCURRENT_OLLAMA_TASKS=16
# AUTOMATION_MAX_CONCURRENT_TASKS=16
# AUTOMATION_EXECUTOR_MAX_WORKERS=8
# Router: lower AUTOMATION_ROUTER_CPU_HOT_HEADROOM = spill cpu_light → gpu only when CPU is hotter; raise AUTOMATION_ROUTER_GPU_EXTRA_HEADROOM = need more GPU headroom before that spill.
# Scheduler throughput (automation_manager)
# AUTOMATION_SCHEDULER_TICK_SECONDS=5
# AUTOMATION_WORKLOAD_MIN_COOLDOWN_SECONDS=10
# WORKLOAD_BALANCER_ENABLED=true
# AUTOMATION_DISABLE_DYNAMIC_TASK_SCALING=true
# Softer router cooldown multipliers (defaults in code: db 2.0, gpu sat 1.5, cpu hot 1.3, headroom 0.85)
# AUTOMATION_ROUTER_COOLDOWN_MULT_DB_PRESSURE=2.0
# AUTOMATION_ROUTER_COOLDOWN_MULT_GPU_SATURATED=1.5
# AUTOMATION_ROUTER_COOLDOWN_MULT_CPU_HOT=1.3
# AUTOMATION_ROUTER_COOLDOWN_MULT_HEADROOM=0.85
# Claim / event extraction batch tuning
# CLAIM_EXTRACTION_BATCH_LIMIT=4000
# CLAIM_EXTRACTION_PARALLEL=48
# EVENT_EXTRACTION_PARALLEL=8
# DB worker pool (raise only if Postgres max_connections / PgBouncer allow)
# DB_POOL_WORKER_MAX=28
# GPU thermal guard for Ollama tasks
# GPU_TEMP_THROTTLE_C=84
# GPU_THROTTLE_SLEEP_SECONDS=30
# Min seconds between GPU samples written to public.gpu_metric_samples (Monitor history)
# GPU_METRIC_SAMPLE_MIN_SECONDS=55
# Combined task_queue + requested queue depth: pause most scheduled enqueues when >= cap. Default 0 = off (use workers + Ollama + DB for limits).
# AUTOMATION_QUEUE_SOFT_CAP=0
# Phases still allowed to enqueue when cap > 0 and depth >= cap (comma-separated). Do not add nightly_enrichment_context — it stacks redundant drains.
# AUTOMATION_QUEUE_PAUSE_ALLOW=collection_cycle,content_enrichment,health_check,pending_db_flush,content_refinement_queue
# Max immediate re-enqueues per batch phase per analysis window after a run (0 = unlimited). Optional override of orchestrator_governance.yaml analysis_pipeline.max_requeue_per_window.
# AUTOMATION_MAX_REQUEUE_PER_WINDOW=0
# Cap running + queued nightly_enrichment_context (one unified drain per run; default 5). 0 = unlimited (not recommended).
# Cap stacked nightly_enrichment_context (running + queues). Default 1 = one sweep at a time.
# AUTOMATION_NIGHTLY_ENRICHMENT_MAX_QUEUED=1
# Cap scheduled asyncio-queue depth per phase (default 1). Prevents workload-driven ticks from stacking
# thousands of duplicate Task objects while prior runs are still pending. 0 = unlimited (legacy).
# AUTOMATION_MAX_SCHEDULED_DEPTH_PER_PHASE=1
# Max workers running the same phase at once (default 2). Spreads daytime automation across phases.
# nightly_sequential_drain bypasses. 0 = unlimited. Nightly window: cap × AUTOMATION_PER_PHASE_CONCURRENT_NIGHTLY_MULT.
# AUTOMATION_PER_PHASE_CONCURRENT_CAP=2
# AUTOMATION_PER_PHASE_CONCURRENT_NIGHTLY_MULT=4
# Phases that do NOT multiply the cap at night (default: claim_extraction). Stops 2×4=8 concurrent huge LLM batches.
# AUTOMATION_PER_PHASE_NIGHTLY_MULT_EXCLUDE=claim_extraction
# Per-phase worker overrides (optional): claim_extraction:1 keeps one claim batch at a time.
# AUTOMATION_PER_PHASE_CONCURRENT_CAP_OVERRIDES=claim_extraction:1
# AUTOMATION_PER_PHASE_CONCURRENT_CAP_PHASES=claim_extraction,claims_to_facts,...
# Defer new automation work when the worker DB pool is hot (reduces connection pool exhaustion). Exempt phases still schedule.
# AUTOMATION_DB_POOL_PRESSURE_GATE_ENABLED=true
# AUTOMATION_DB_WORKER_UTILIZATION_SKIP_THRESHOLD=0.82
# Extra comma-separated phase names always allowed when pool is hot (defaults include health_check,pending_db_flush).
# AUTOMATION_DB_POOL_GATE_EXEMPT_PHASES=
# Cap in-batch LLM fanout outside unified nightly window (0 = use CLAIM_EXTRACTION_PARALLEL only).
# CLAIM_EXTRACTION_PARALLEL_DAYTIME_MAX=8
# Claim extraction: default one automation task loops batches until backlog empty (CLAIM_EXTRACTION_DRAIN=true).
# Other workers stay on other phases; GPU sharing uses LLM lanes + resource router, not many queued claim_extraction tasks.
# CLAIM_EXTRACTION_DRAIN=false
# Optional guards on that single long task (0 = unlimited): max inner batches, wall seconds, or stop after N consecutive
# batches with contexts processed but 0 claims inserted (stuck strict_seeded / parse).
# CLAIM_EXTRACTION_DRAIN_MAX_BATCHES=0
# CLAIM_EXTRACTION_DRAIN_MAX_SECONDS=0
# CLAIM_EXTRACTION_DRAIN_MAX_ZERO_CLAIM_BATCHES=3
# Sub-batch gather size (0 = auto: max(PARALLEL*10, 96)). Smaller = more frequent progress logs, fewer simultaneous coroutines.
# CLAIM_EXTRACTION_INTERNAL_CHUNK=120

# Content Prioritization
PRIORITY_UPDATE_INTERVAL=300
PRIORITY_BATCH_SIZE=25

# Daily Briefings
BRIEFING_SCHEDULE=0 8 * * *
BRIEFING_TEMPLATE=default

# System Alerts
ALERT_EMAIL=
ALERT_WEBHOOK=
ALERT_THRESHOLD=0.8

# ML Configuration
ML_MODEL_PATH=/app/models
ML_BATCH_SIZE=32
ML_CONFIDENCE_THRESHOLD=0.7

# RAG Configuration
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
# api/services/rag/retrieval.py semantic search: cosine floor and pool-relative cutoff (max of floor, relative×best in candidate pool)
RAG_SEMANTIC_SIMILARITY_THRESHOLD=0.3
RAG_SEMANTIC_RELATIVE_TO_BEST=0.82
RAG_SEMANTIC_ADAPTIVE_MIN_CANDIDATES=4

# Performance Monitoring
PERF_MONITORING_ENABLED=true
PERF_SAMPLE_RATE=0.1

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# Logging Configuration
LOG_FORMAT=json
LOG_ROTATION_SIZE=100MB
LOG_ROTATION_COUNT=10

# API Documentation
API_DOCS_ENABLED=true
API_DOCS_URL=/docs

# CORS Configuration
CORS_ORIGINS=*
CORS_METHODS=GET,POST,PUT,DELETE
CORS_HEADERS=*

# Session Configuration
SESSION_SECRET=your_session_secret_here_change_this
SESSION_TIMEOUT=3600

# WebSocket Configuration
WEBSOCKET_ENABLED=true
WEBSOCKET_PORT=8001

# Task Queue Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true

# Background Tasks
BACKGROUND_TASK_ENABLED=true
BACKGROUND_TASK_WORKERS=2

# Data Processing
DATA_PROCESSING_BATCH_SIZE=100
DATA_PROCESSING_TIMEOUT=300

# Export Configuration
EXPORT_FORMATS=json,csv,xlsx
EXPORT_MAX_RECORDS=10000

# Import Configuration
IMPORT_BATCH_SIZE=50
IMPORT_TIMEOUT=180

# Notification Configuration
NOTIFICATION_ENABLED=true
NOTIFICATION_CHANNELS=email,webhook

# System Maintenance
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System under maintenance

# Nightly automation window (optional; see api/services/nightly_ingest_window_service.py)
# Default 02:00–07:00 local (Eastern): one RSS kickoff/day, drain enrichment → context_sync → NIGHTLY_SEQUENTIAL_PHASES → GPU refinement.
# NIGHTLY_PIPELINE_TZ=America/New_York
# NIGHTLY_PIPELINE_START_HOUR=2
# NIGHTLY_PIPELINE_END_HOUR=7
# Temporary backlog catch-up: treat pipeline window as 24/7 (same as nightly mode all day). Leave off for normal ops.
# NIGHTLY_PIPELINE_ALL_DAY=false
# NIGHTLY_PIPELINE_EXCLUSIVE=1
# NIGHTLY_PIPELINE_ALLOWED_SCHEDULED_PHASES=nightly_enrichment_context,health_check,pending_db_flush
# NIGHTLY_PIPELINE_KICKOFF_RSS=1
# NIGHTLY_SEQUENTIAL_PHASES= (comma list; empty = built-in order in nightly_ingest_window_service.py)
# NIGHTLY_SEQUENTIAL_PHASE_MAX_LOOPS=2000
# NIGHTLY_SEQUENTIAL_SINGLE_PASS_PHASES=pattern_recognition,pattern_matching,fact_verification,event_deduplication,story_continuation,watchlist_alerts,storyline_enrichment
# NIGHTLY_ENRICHMENT_CONTEXT_START_HOUR=2
# NIGHTLY_ENRICHMENT_CONTEXT_END_HOUR=7
# NIGHTLY_INGEST_EXCLUSIVE_AUTOMATION=0
# When exclusive is on, only these phases may run during the enrichment-context sub-window (default in code includes extraction pipeline).
# NIGHTLY_INGEST_ALLOW=nightly_enrichment_context,content_enrichment,health_check,pending_db_flush,collection_cycle,claim_extraction,legislative_references,claims_to_facts,claim_subject_gap_refresh,extracted_claims_dedupe,event_tracking,topic_clustering,quality_scoring,sentiment_analysis,entity_profile_sync,entity_extraction,ml_processing,metadata_enrichment,event_extraction,event_deduplication
# NIGHTLY_ENRICHMENT_BATCH_SIZE=80
# NIGHTLY_CONTEXT_SYNC_LIMIT_PER_DOMAIN=200
# NIGHTLY_ENRICHMENT_MAX_LOOPS=2000
# NIGHTLY_CONTEXT_SYNC_MAX_LOOPS=2000
# CONTENT_REFINEMENT_NIGHTLY_MAX_FINISHER_JOBS_PER_CYCLE= (see content_refinement_queue_service)
# CONTENT_REFINEMENT_NIGHTLY_MAX_JOBS_PER_CYCLE= (see content_refinement_queue_service)