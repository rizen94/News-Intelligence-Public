# Optional overlay for public HTTPS demo — copy to project root on Widow as:
#   /opt/news-intelligence/.env.public_demo
# systemd unit `news-intelligence-api-public.service` loads it after `.env`.
# Adjust hostnames to match your DuckDNS (or other) name.

NEWS_INTEL_ENV=production
NEWS_INTEL_TRUSTED_HOSTS=yourname.duckdns.org,localhost,127.0.0.1
NEWS_INTEL_CORS_ORIGINS=https://yourname.duckdns.org

# Server-enforced read-only for visitors hitting the public hostname (see api/shared/middleware/demo_readonly.py)
NEWS_INTEL_DEMO_READ_ONLY=true
NEWS_INTEL_DEMO_HOSTS=yourname.duckdns.org

# NEWS_INTEL_DEMO_READ_ONLY_ALL=false
# NEWS_INTEL_DEMO_POST_ALLOWLIST=

NEWS_INTEL_SQL_EXPLORER=false
# LOG_LLM_FULL_TEXT=false
