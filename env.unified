# News Intelligence System v3.0 - Unified Environment Configuration
# All-in-one package with NAS storage and full feature set

# ============================================================================
# CORE SYSTEM CONFIGURATION
# ============================================================================

# Database Configuration
DB_PASSWORD=Database@NEWSINT2025
DB_HOST=postgres
DB_NAME=news_system
DB_USER=NewsInt_DB

# Redis Configuration
REDIS_PASSWORD=redis_password_123

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# RSS Collection Settings
RSS_INTERVAL_MINUTES=60
MAX_CONCURRENT_RSS_FEEDS=10
MAX_CONCURRENT_ARTICLES=100

# Data Management
PRUNING_INTERVAL_HOURS=12
MAX_RUNTIME_HOURS=24
CLEANUP_INTERVAL_HOURS=6
MAX_LOG_SIZE_MB=100
MAX_TEMP_FILES=1000

# Logging
LOG_LEVEL=INFO

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================

# Database Performance
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_AUTOVACUUM_MAX_WORKERS=3
POSTGRES_AUTOVACUUM_NAPTIME=1min
DATABASE_POOL_SIZE=10

# Redis Performance
REDIS_POOL_SIZE=20

# ============================================================================
# MONITORING CONFIGURATION
# ============================================================================

# Grafana
GRAFANA_PASSWORD=Database@NEWSINT2025
GRAFANA_ANONYMOUS_ACCESS=false

# Prometheus
PROMETHEUS_RETENTION_DAYS=30

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# Security Keys (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your_jwt_secret_here_change_this
ENCRYPTION_KEY=your_encryption_key_here_change_this

# SSL/TLS
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

# ============================================================================
# ML AND AI FEATURES
# ============================================================================

# External AI Services (Optional - for enhanced ML features)
OPENAI_API_KEY=your_openai_api_key_here
HUGGINGFACE_TOKEN=your_huggingface_token_here

# ML Processing
ENABLE_ML_PROCESSING=true
ENABLE_RAG_ENHANCED=true
ENABLE_LIVING_NARRATOR=true
ENABLE_STORYLINE_TRACKING=true
ENABLE_DAILY_DIGESTS=true

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================

BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM

# ============================================================================
# NAS STORAGE PATHS
# ============================================================================

# All data is stored on NAS for persistence
NAS_BASE_PATH=/mnt/terramaster-nas/docker-postgres-data
NAS_POSTGRES_DATA=${NAS_BASE_PATH}/pgdata
NAS_APPLICATION_DATA=${NAS_BASE_PATH}/data
NAS_LOGS=${NAS_BASE_PATH}/logs
NAS_BACKUPS=${NAS_BASE_PATH}/backups
NAS_TEMP=${NAS_BASE_PATH}/temp
NAS_ML_MODELS=${NAS_BASE_PATH}/ml-models
NAS_CACHE=${NAS_BASE_PATH}/cache
NAS_UPLOADS=${NAS_BASE_PATH}/uploads
NAS_PROMETHEUS_DATA=${NAS_BASE_PATH}/prometheus-data
NAS_GRAFANA_DATA=${NAS_BASE_PATH}/grafana-data
NAS_REDIS_DATA=${NAS_BASE_PATH}/redis-data
NAS_NGINX_LOGS=${NAS_BASE_PATH}/nginx-logs

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable all advanced features by default
ENABLE_MONITORING=true
ENABLE_GPU_MONITORING=false
ENABLE_NGINX_PROXY=false
ENABLE_SSL_TERMINATION=false

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Set to false in production
DEBUG=false
DEVELOPMENT_MODE=false
