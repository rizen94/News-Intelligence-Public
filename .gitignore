# News Intelligence — Git ignore (see docs/GITIGNORE.md for rationale tables)

# Database files and data directories
db_data/
*.db
*.sqlite
postgres_data/
redis_data/

# Docker volumes and data
docker/data/
volumes/
data/

# Virtual environments
venv/
env/
.venv/
.venv.backup/
.venv-report/

# Python cache and compiled files
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Environment files
.env
.env.local
.env.production
configs/ddns.env
config/.secrets
api/config/.secrets

# Logs
*.log
logs/
log/

# Temporary files
temp/
tmp/
*.tmp
*.temp
api/temp/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# AI Assistant files (legacy)
.aider/
.aider.*
*.aider*

# Code assistant files (legacy)
*code-assistant*
*aider*
*ollama*

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Backup files
backups/
*.backup
*.bak

# Test coverage
.coverage
htmlcov/
.pytest_cache/

# Node.js (if any)
node_modules/
npm-debug.log*

# Large data files
*.csv
models/

# Large backup and export files
news-system-backup-*/
news-system-export*.zip
*.zip
*.tar
*.tar.gz
*.7z

# PID files
*.pid

# Relocated archive (27GB, 508k files - kept external) — repo root only; do not use
# bare `archive/` (that would ignore api/database/migrations/archive/).
/archive/

# Generated pi reports (scripts/pi_*.sh output)
scripts/pi_reports/

# Migration state overrides (may contain IPs, do not commit secrets)
infrastructure/*.local.json
infrastructure/migration-state.local.json
.db_password_widow

# Local / machine-specific notes (do not commit)
my_docker.txt
my_pihole.txt

# Documentation obfuscation: real LAN IPs / paths (never commit)
configs/doc_obfuscation.local.yaml
configs/doc_obfuscation.local.yml
docs/_local_expanded/
