# News Intelligence — environment variables
# Copy to .env and set values. See configs/env.example for full list.

# Core — Widow (secondary) or NAS via tunnel
DB_HOST=192.168.93.101
DB_PORT=5432
DB_NAME=news_intel
DB_USER=newsapp
DB_PASSWORD=

# Rollback to NAS: DB_HOST=localhost DB_PORT=5433 DB_NAME=news_intelligence

# Ollama
OLLAMA_HOST=http://localhost:11434

# Finance domain (optional — for market data)
FRED_API_KEY=
BIGQUERY_PROJECT_ID=
EDGAR_USER_AGENT=NewsIntelligence research@example.com

# Knowledge Graph API (free tier: 100K queries/day)
# https://developers.google.com/knowledge-graph/how-tos/authorizing
KG_API_KEY=

# Optional
LOG_LEVEL=INFO
NEWS_INTEL_ARCHIVE_DIR=/media/pete/Fortress2/news-intelligence-archive
